{
  "name": "@tlx/cli",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "tlx": "./dist/index.js"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts ui:start",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --target bun --outfile dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6"
  }
}
