{
  "name": "tlx",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --filter './apps/*' dev",
    "dev:cli": "bun --filter @tlx/cli dev",
    "dev:ui": "bun --filter @tlx/ui dev",
    "build": "bun run --filter './apps/*' build",
    "build:cli": "bun --filter @tlx/cli build",
    "build:ui": "bun --filter @tlx/ui build",
    "typecheck": "bun run --filter './apps/*' typecheck",
    "lint": "bun run --filter './apps/*' lint",
    "check": "bun run typecheck && bun run lint"
  },
  "devDependencies": {
    "@types/bun": "^1.3.2",
    "bun-types": "1.3.14",
    "typescript": "^5"
  }
}
