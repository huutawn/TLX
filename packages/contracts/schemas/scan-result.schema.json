{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tlx.local/schemas/scan-result.schema.json",
  "title": "TlxScanResultResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["success", "totalElementsScanned", "bugsFound", "timestamp", "report"],
  "properties": {
    "success": { "type": "boolean" },
    "totalElementsScanned": { "type": "integer", "minimum": 0 },
    "bugsFound": {
      "type": "array",
      "items": { "type": "string" }
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "report": { "$ref": "#/$defs/report" }
  },
  "$defs": {
    "boundingBox": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number", "minimum": 0 },
        "height": { "type": "number", "minimum": 0 }
      }
    },
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "severity", "message", "route", "url", "selector", "boundingBox", "metadata"],
      "properties": {
        "id": { "type": "string" },
        "kind": { "enum": ["overlap", "overflow", "contrast", "color_harmony", "crawler", "api", "auth_required", "auth_failed"] },
        "severity": { "enum": ["info", "warning", "error"] },
        "message": { "type": "string" },
        "route": { "type": "string" },
        "url": { "type": "string" },
        "selector": { "type": "string" },
        "boundingBox": { "$ref": "#/$defs/boundingBox" },
        "screenshotPath": { "type": "string" },
        "metadata": { "type": "object" }
      }
    },
    "report": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "scope", "startedAt", "finishedAt", "success", "summary", "issues", "screenshots", "warnings"],
      "properties": {
        "id": { "type": "string" },
        "scope": { "enum": ["changed", "all", "route"] },
        "startedAt": { "type": "string", "format": "date-time" },
        "finishedAt": { "type": "string", "format": "date-time" },
        "success": { "type": "boolean" },
        "summary": {
          "type": "object",
          "additionalProperties": false,
          "required": ["routesScanned", "elementsScanned", "issuesFound", "screenshotsCaptured"],
          "properties": {
            "routesScanned": { "type": "integer", "minimum": 0 },
            "elementsScanned": { "type": "integer", "minimum": 0 },
            "issuesFound": { "type": "integer", "minimum": 0 },
            "screenshotsCaptured": { "type": "integer", "minimum": 0 }
          }
        },
        "issues": { "type": "array", "items": { "$ref": "#/$defs/issue" } },
        "screenshots": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "colorAnalysis": { "$ref": "#/$defs/colorAnalysis" }
      }
    },
    "oklchColor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lightness", "chroma", "hue"],
      "properties": {
        "lightness": { "type": "number" },
        "chroma": { "type": "number", "minimum": 0 },
        "hue": { "type": ["number", "null"], "minimum": 0, "maximum": 360 }
      }
    },
    "paletteEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "color", "oklch", "weight"],
      "properties": {
        "role": { "type": "string" },
        "color": { "type": "string" },
        "oklch": { "$ref": "#/$defs/oklchColor" },
        "weight": { "type": "number", "minimum": 0 }
      }
    },
    "routeColorAnalysis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["route", "viewport", "score", "dominantHue", "strongHueFamilies", "hueSpread", "highChromaAreaRatio", "palette"],
      "properties": {
        "route": { "type": "string" },
        "viewport": { "type": "string" },
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "dominantHue": { "type": ["number", "null"], "minimum": 0, "maximum": 360 },
        "strongHueFamilies": { "type": "integer", "minimum": 0 },
        "hueSpread": { "type": "number", "minimum": 0, "maximum": 180 },
        "highChromaAreaRatio": { "type": "number", "minimum": 0 },
        "palette": { "type": "array", "items": { "$ref": "#/$defs/paletteEntry" } }
      }
    },
    "colorAnalysis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "score", "dominantHue", "thresholds", "routes"],
      "properties": {
        "enabled": { "type": "boolean" },
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "dominantHue": { "type": ["number", "null"], "minimum": 0, "maximum": 360 },
        "thresholds": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maxStrongHueFamilies", "maxRouteHueDrift", "maxHighChromaAreaRatio", "maxHueSpread"],
          "properties": {
            "maxStrongHueFamilies": { "type": "integer", "minimum": 1 },
            "maxRouteHueDrift": { "type": "number", "minimum": 0, "maximum": 180 },
            "maxHighChromaAreaRatio": { "type": "number", "minimum": 0 },
            "maxHueSpread": { "type": "number", "minimum": 0, "maximum": 180 }
          }
        },
        "routes": { "type": "array", "items": { "$ref": "#/$defs/routeColorAnalysis" } }
      }
    }
  }
}
