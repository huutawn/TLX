{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tlx.local/schemas/cache-diff.schema.json",
  "title": "TlxCacheDiffResponse",
  "type": "object",
  "additionalProperties": false,
  "required": ["changed", "unchanged", "unknown", "deleted", "affectedRoutes"],
  "properties": {
    "changed": { "type": "array", "items": { "$ref": "#/$defs/cacheEntry" } },
    "unchanged": { "type": "array", "items": { "$ref": "#/$defs/cacheEntry" } },
    "unknown": { "type": "array", "items": { "$ref": "#/$defs/cacheEntry" } },
    "deleted": { "type": "array", "items": { "$ref": "#/$defs/cacheEntry" } },
    "affectedRoutes": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "cacheEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": { "type": "string" },
        "hash": { "type": "string" },
        "route": { "type": "string" }
      }
    }
  }
}
